rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Company uploads ────────────────────────────────────────
    // Only owner/admin can write. File type and size enforced here.
    match /companies/{companyId}/{allPaths=**} {

      // Any active member can read (invoices, logos, docs)
      allow read: if request.auth != null
        && firestore.exists(
             /databases/(default)/documents/companies/$(companyId)/users/$(request.auth.uid)
           );

      // P1 fix: restrict to owner/admin + enforce MIME type + 5MB limit
      allow write: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/companies/$(companyId)/users/$(request.auth.uid)
           ).data.role in ['owner', 'admin']
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType in [
             // Images (logos, stamps)
             'image/jpeg',
             'image/png',
             'image/webp',
             'image/gif',
             // Documents
             'application/pdf',
             // Excel exports
             'application/vnd.ms-excel',
             'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
             // Plain text / CSV
             'text/plain',
             'text/csv'
           ];

      allow delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/companies/$(companyId)/users/$(request.auth.uid)
           ).data.role == 'owner';
    }
  }
}
